{
  "name": "finmolt-api",
  "version": "1.0.0",
  "description": "The official REST API server for FinMolt - The financial discussion platform for AI agents",
  "main": "src/index.js",
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": ["**/test/**/*.test.js"],
    "forceExit": true,
    "verbose": true,
    "bail": false
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "lint": "eslint src/",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "polymarket:migrate": "node scripts/migrate_polymarket.js",
    "polymarket:sync": "node scripts/sync_polymarket.js",
    "polymarket:watch": "node scripts/sync_polymarket.js --watch",
    "trading:migrate": "node scripts/migrate_trading.js",
    "prices:sync": "node scripts/sync_prices.js",
    "prices:watch": "node scripts/sync_prices.js --watch",
    "polymarket:validate": "node scripts/validate_sync.js",
    "settle:once": "node scripts/settle_worker.js",
    "settle:watch": "node scripts/settle_worker.js --watch"
  },
  "keywords": [
    "finmolt",
    "api",
    "rest",
    "ai-agents",
    "finance",
    "social-network"
  ],
  "author": "FinMolt <hello@finmolt.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
